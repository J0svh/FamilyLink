generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String   @id @default(uuid()) @db.Uuid
  email                 String   @unique @db.VarChar(255)
  username              String   @db.VarChar(100)
  passwordHash          String   @map("password_hash") @db.VarChar(255)
  language              String   @default("es") @db.VarChar(5)
  privacyModeActive     Boolean  @default(false) @map("privacy_mode_active")
  privacyModeExpiresAt  DateTime? @map("privacy_mode_expires_at")
  privacyModeCountToday Int      @default(0) @map("privacy_mode_count_today")
  privacyModeResetDate  DateTime? @map("privacy_mode_reset_date") @db.Date
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  circlesCreated   Circle[]         @relation("CircleCreator")
  memberships      CircleMember[]
  locationUpdates  LocationUpdate[]
  invitationsSent  Invitation[]     @relation("InvitationSender")
  refreshTokens    RefreshToken[]

  @@map("users")
}

model Circle {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(50)
  createdBy String   @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  creator         User             @relation("CircleCreator", fields: [createdBy], references: [id])
  members         CircleMember[]
  zones           Zone[]
  locationUpdates LocationUpdate[]
  invitations     Invitation[]
  dailyLimits     DailyLimit[]

  @@map("circles")
}

model CircleMember {
  id       String   @id @default(uuid()) @db.Uuid
  circleId String   @map("circle_id") @db.Uuid
  userId   String   @map("user_id") @db.Uuid
  role     String   @db.VarChar(20) // 'circle_admin' | 'circle_member'
  joinedAt DateTime @default(now()) @map("joined_at")

  circle Circle @relation(fields: [circleId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([circleId, userId])
  @@map("circle_members")
}

model Zone {
  id              String   @id @default(uuid()) @db.Uuid
  circleId        String   @map("circle_id") @db.Uuid
  createdBy       String   @map("created_by") @db.Uuid
  name            String   @db.VarChar(100)
  nameEn          String?  @map("name_en") @db.VarChar(100)
  colorHex        String   @map("color_hex") @db.VarChar(7)
  polygonVertices Json     @map("polygon_vertices") // Array<{lat: number, lng: number}>
  areaSqm         Float    @map("area_sqm")
  active          Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  circle Circle @relation(fields: [circleId], references: [id], onDelete: Cascade)

  @@index([circleId])
  @@map("zones")
}

model LocationUpdate {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  circleId   String   @map("circle_id") @db.Uuid
  latitude   Float
  longitude  Float
  capturedAt DateTime @map("captured_at")
  createdAt  DateTime @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  circle Circle @relation(fields: [circleId], references: [id], onDelete: Cascade)

  @@index([circleId, capturedAt(sort: Desc)])
  @@index([userId, capturedAt(sort: Desc)])
  @@map("location_updates")
}

model Invitation {
  id        String   @id @default(uuid()) @db.Uuid
  circleId  String   @map("circle_id") @db.Uuid
  invitedBy String   @map("invited_by") @db.Uuid
  email     String   @db.VarChar(255)
  status    String   @default("pending") @db.VarChar(20) // 'pending' | 'accepted' | 'expired' | 'revoked'
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  circle  Circle @relation(fields: [circleId], references: [id], onDelete: Cascade)
  inviter User   @relation("InvitationSender", fields: [invitedBy], references: [id])

  @@index([email, status])
  @@map("invitations")
}

model DailyLimit {
  id         String   @id @default(uuid()) @db.Uuid
  circleId   String   @map("circle_id") @db.Uuid
  role       String   @db.VarChar(20) // 'circle_admin' | 'circle_member'
  maxUpdates Int      @map("max_updates")
  updatedAt  DateTime @updatedAt @map("updated_at")

  circle Circle @relation(fields: [circleId], references: [id], onDelete: Cascade)

  @@unique([circleId, role])
  @@map("daily_limits")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @map("token_hash") @db.VarChar(255)
  revoked   Boolean  @default(false)
  revokedAt DateTime? @map("revoked_at")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([userId])
  @@map("refresh_tokens")
}
